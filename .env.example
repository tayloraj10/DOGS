# Database (local docker-compose uses POSTGRES_HOST=db inside the api container)
POSTGRES_DB=dogs_db
POSTGRES_USER=dogs_user
POSTGRES_PASSWORD=dogs_password
POSTGRES_HOST=localhost
# Host port when using docker compose (5433 avoids conflict with CAN on 5432)
POSTGRES_PORT=5433

# Optional override (Cloud SQL / proxy)
DATABASE_URL=
DB_PASSWORD=

# Runtime
ENVIRONMENT=development

# Google Sheet (Directory of Good) — optional for sync
GOOGLE_SHEETS_SPREADSHEET_ID=1KVYFjM8E_c65hzia2LWgtwvO9UKeqUXJpsfhB2OeOAo
GOOGLE_SHEETS_SHEET_GID=1363212709
# Path to service account JSON (e.g. creds/service-account.json)
GOOGLE_APPLICATION_CREDENTIALS=

# Geocoding — optional for sync / import
GOOGLE_MAPS_GEOCODING_API_KEY=

# Cloud Storage — for re-hosting directory entry photos (optional; uploads disabled if unset)
GCS_DIRECTORY_IMAGES_BUCKET=
GCS_PROJECT_ID=
